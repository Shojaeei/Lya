# ═══════════════════════════════════════════════════════════════
# Lya Configuration - Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# General
# ───────────────────────────────────────────────────────────────
LYA_ENV=production
LYA_DEBUG=false
LYA_LOG_LEVEL=INFO
LYA_WORKSPACE_PATH=~/.lya/

# ───────────────────────────────────────────────────────────────
# LLM Configuration
# ───────────────────────────────────────────────────────────────
LYA_LLM_PROVIDER=ollama
LYA_LLM_MODEL=kimi-k2.5:cloud
LYA_LLM_BASE_URL=http://localhost:11434
LYA_LLM_TEMPERATURE=0.7
LYA_LLM_MAX_TOKENS=16384
LYA_LLM_TIMEOUT=60
LYA_LLM_OLLAMA_API_KEY=

# ───────────────────────────────────────────────────────────────
# Telegram Bot (REQUIRED)
# ───────────────────────────────────────────────────────────────
LYA_TELEGRAM_BOT_TOKEN=
LYA_TELEGRAM_ALLOWED_USERS=
LYA_TELEGRAM_STREAMING=true
LYA_TELEGRAM_STREAM_EDIT_INTERVAL=2.0

# ───────────────────────────────────────────────────────────────
# Memory & Embeddings
# ───────────────────────────────────────────────────────────────
LYA_MEMORY_VECTOR_DB=chroma
LYA_MEMORY_DB_PATH=~/.lya/memory
LYA_MEMORY_EMBEDDING_MODEL=nomic-embed-text
LYA_MEMORY_EMBEDDING_DIMENSION=768

# ───────────────────────────────────────────────────────────────
# Security
# ───────────────────────────────────────────────────────────────
LYA_SECURITY_SANDBOX_ENABLED=true
LYA_SECURITY_SANDBOX_TYPE=process
LYA_SECURITY_ALLOW_FILE_WRITE=true
LYA_SECURITY_ALLOW_NETWORK_ACCESS=true
LYA_SECURITY_ALLOWED_DIRECTORIES=["~/.lya"]
LYA_SECURITY_BLOCKED_COMMANDS=["rm -rf","dd","format","mkfs"]

# ───────────────────────────────────────────────────────────────
# Voice (optional)
# ───────────────────────────────────────────────────────────────
LYA_VOICE_ENABLED=false
LYA_VOICE_STT_ENGINE=whisper
LYA_VOICE_TTS_ENGINE=pyttsx3

# ───────────────────────────────────────────────────────────────
# API Server (optional)
# ───────────────────────────────────────────────────────────────
LYA_API_HOST=0.0.0.0
LYA_API_PORT=8000
